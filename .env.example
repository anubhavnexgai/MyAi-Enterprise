# ── Azure Bot Framework ──
MICROSOFT_APP_ID=your-azure-bot-app-id
MICROSOFT_APP_PASSWORD=your-azure-bot-app-secret

# ── Ollama ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Security ──
ALLOWED_USERS=*
# Comma-separated Teams user IDs, or * for all

# ── Web Search ──
SEARCH_PROVIDER=duckduckgo
# Options: duckduckgo, tavily
TAVILY_API_KEY=

# ── Gemini (Optional for better RAG) ──
GEMINI_API_KEY=

# ── Storage ──
DATABASE_PATH=data/openclaw.db
CHROMA_PATH=data/chroma

# ── Meeting Transcript ──
MEETING_SUGGESTION_DEBOUNCE_SECONDS=15
MEETING_TRANSCRIPT_MAX_CHARS=12000
MEETING_SUGGESTION_MODEL=
# Leave empty to use OLLAMA_MODEL; set to override (e.g. mistral:7b)
CALLBACK_HOST=
# Your public ngrok/tunnel URL, e.g. https://xxxx.ngrok-free.app
TRANSCRIPT_WEBHOOK_SECRET=miai-transcript-secret
# Change this to a random string in production
