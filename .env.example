# -- Slack --
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# -- Ollama --
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# -- Server (debug HTTP only) --
HOST=0.0.0.0
PORT=8001

# -- Security --
ALLOWED_USERS=*
# Comma-separated Slack user IDs, or * for all

# -- Web Search --
SEARCH_PROVIDER=duckduckgo
# Options: duckduckgo, tavily
TAVILY_API_KEY=

# -- Gemini (Optional for better RAG) --
GEMINI_API_KEY=

# -- Storage --
DATABASE_PATH=data/miai.db
CHROMA_PATH=data/chroma

# -- Microsoft Graph (optional: enables calendar/email/files in Slack) --
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_TENANT_ID=
# Use "common" for multi-tenant, or your Azure AD tenant ID
GRAPH_REDIRECT_URI=http://localhost:8001/auth/callback
# Must match the redirect URI in your Azure App Registration

# -- Meeting Transcript --
MEETING_SUGGESTION_DEBOUNCE_SECONDS=15
MEETING_TRANSCRIPT_MAX_CHARS=12000
MEETING_SUGGESTION_MODEL=
# Leave empty to use OLLAMA_MODEL; set to override (e.g. mistral:7b)

# -- NexgAI Platform (optional: enables 24+ specialized AI agents) --
NEXGAI_ENABLED=false
NEXGAI_BASE_URL=https://your-nexgai-instance.com
NEXGAI_TENANT_ID=
NEXGAI_SERVICE_USER=
NEXGAI_SERVICE_PASSWORD=
NEXGAI_TIMEOUT=30
NEXGAI_STREAM_TIMEOUT=120
NEXGAI_CIRCUIT_BREAKER_THRESHOLD=3
NEXGAI_CIRCUIT_BREAKER_COOLDOWN=60
NEXGAI_AGENT_CACHE_TTL=300

# -- AgentHub (Phase 2) --
AGENTHUB_ENABLED=false
AGENTHUB_BASE_URL=
AGENTHUB_API_KEY=
AGENTHUB_TENANT_ID=enterprise_copilot

# -- Self-Learning Loop (Phase 4) --
LEARNING_INTERVAL_HOURS=6
LEARNING_MIN_NEGATIVE_FEEDBACK=3
